# Base de datos PostgreSQL (Railway provee esta URL automáticamente)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Puerto del servidor
PORT=3001

# Token de verificación del webhook de Meta (elegís vos, cualquier string)
WEBHOOK_VERIFY_TOKEN=mi_token_secreto_aqui

# URL del frontend (para CORS en producción)
FRONTEND_URL=https://tu-frontend.railway.app
